{
  "name": "deep-immutable-ts",
  "version": "1.0.0",
  "description": "Deep immutable TypeScript types and utility functions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Alexey Kosterin",
  "license": "MIT",
  "type": "commonjs",  
  "keywords": [
    "typescript",
    "immutable",
    "readonly",
    "deep-freeze",
    "deep-immutable",
    "freeze",
    "immutability",
    "utility-types"
  ],  
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KostAlex07/deep-immutable-ts.git"
  },
  "bugs": {
    "url": "https://github.com/KostAlex07/deep-immutable-ts/issues"
  },
  "homepage": "https://github.com/KostAlex07/deep-immutable-ts#readme",
  "sideEffects": false,
  "exports": {
  ".": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.js"
  }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
